# Copy to .env only on the server. Never commit the real values.
LIVE_ON_ENV=development
LIVE_ON_DATABASE_PATH=./data/live-on.db
LIVE_ON_SCREENSHOT_DIRECTORY=./data/screenshots
# Optional. Leave empty when the client should resolve /v1/screenshots against the API URL.
LIVE_ON_SCREENSHOT_BASE_URL=
LIVE_ON_PUBLIC_BASE_URL=https://liveonplugin.discloud.app
LIVE_ON_MEMBER_SITE_BASE_URL=https://liveon.discloud.app
LIVE_ON_TOKEN_SECRET=replace-with-at-least-32-random-characters

# sha256 of the code distributed by the staff. Example command:
# PowerShell: ([BitConverter]::ToString([Security.Cryptography.SHA256]::HashData([Text.Encoding]::UTF8.GetBytes('your-code')))).Replace('-','').ToLower()
LIVE_ON_ACCESS_CODE_SHA256=

# Wise Old Man group ID for the official Live On roster.
LIVE_ON_WOM_GROUP_ID=0
LIVE_ON_WOM_API_KEY=

# RuneProfile works without a key (30 requests/minute). A key only raises the limit.
LIVE_ON_RUNEPROFILE_BASE_URL=https://api.runeprofile.com/v1
LIVE_ON_RUNEPROFILE_API_KEY=

# Development/bootstrap fallback: comma-separated rsn:role values.
LIVE_ON_BOOTSTRAP_MEMBERS=Example Member:member,Example Staff:administrator
LIVE_ON_STAFF_RSNS=Example Staff

# Discord webhook stays on the server; it is never sent to RuneLite clients.
LIVE_ON_DISCORD_WEBHOOK=
LIVE_ON_LOGIN_MESSAGE=Bem-vindo à Live On! Confira os anúncios no painel lateral.
LIVE_ON_CORS_ORIGINS=https://liveonclan.com
LIVE_ON_TOKEN_LIFETIME_SECONDS=43200
